---
interface Props {
  title: string;
  description: string;
  tags: string[];
  link: string;
  class?: string;
}

const { title, description, tags, link, class: className } = Astro.props;
---

<a 
  href={link} 
  class={`group relative overflow-hidden rounded-3xl border border-white/10 bg-white/5 p-8 transition-all duration-500 hover:border-white/20 hover:bg-white/10 ${className}`}
>
  <div class="absolute inset-0 z-0 bg-gradient-to-br from-[var(--color-accent)]/5 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>

  <div class="relative z-10 flex h-full flex-col justify-between">
    <div>
      <div class="flex flex-wrap gap-2 mb-4">
        {tags.map(tag => (
          <span class="text-[10px] font-mono uppercase tracking-wider text-gray-400 border border-white/5 px-2 py-1 rounded">
            {tag}
          </span>
        ))}
      </div>
      <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-[var(--color-accent)] transition-colors">
        {title}
      </h3>
      <p class="text-gray-400 text-sm leading-relaxed max-w-[280px]">
        {description}
      </p>
    </div>

    <div class="mt-8 flex items-center text-sm font-medium text-white opacity-0 transition-all duration-300 transform translate-y-2 group-hover:opacity-100 group-hover:translate-y-0">
      Ver proyecto 
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </div>
  </div>
</a>