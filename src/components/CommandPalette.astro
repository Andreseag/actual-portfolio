
<!-- Contenedor Backdrop (Fondo oscuro difuminado) -->
<div 
  id="command-palette" 
  class="fixed inset-0 z-50 flex items-start justify-center p-4 pt-[15vh] bg-black/60 backdrop-blur-sm hidden opacity-0 transition-all duration-300 pointer-events-none"
  role="dialog"
  aria-modal="true"
>
  <!-- Caja de la Consola -->
  <div class="w-full max-w-lg rounded-2xl border border-white/10 bg-zinc-950/90 p-3 shadow-2xl shadow-[--color-accent]/10 transform scale-95 transition-all duration-300 relative overflow-hidden group">
    
    <!-- Resplandor azul interno sutil -->
    <div class="absolute -top-24 -left-24 h-48 w-48 rounded-full bg-[--color-accent]/10 blur-3xl pointer-events-none"></div>

    <!-- Buscador / Input -->
    <div class="flex items-center gap-3 px-3 pb-3 border-b border-white/5">
      <span class="font-mono text-xs text-gray-500">❯</span>
      <input 
        type="text" 
        id="palette-input" 
        placeholder="Escribe un comando o navega con las flechas..." 
        class="w-full bg-transparent text-sm text-white placeholder-gray-500 outline-none border-none font-sans"
        autocomplete="off"
      />
      <span class="font-mono text-[10px] bg-white/5 border border-white/10 px-1.5 py-0.5 rounded text-gray-400">ESC</span>
    </div>

    <!-- Lista de Comandos -->
    <ul id="palette-options" class="mt-2 space-y-1 font-mono text-xs">
      <li>
        <button data-action="goto" data-target="/" class="w-full text-left px-3 py-2.5 rounded-xl text-gray-400 hover:bg-[--color-accent]/10 hover:text-white flex items-center justify-between group/item transition-colors">
          <span>🏠 H_ome <span class="text-gray-600 font-sans font-light">— Ir al inicio</span></span>
          <span class="text-gray-600 group-hover/item:text-[--color-accent]">⌥ 1</span>
        </button>
      </li>
      <li>
        <button data-action="scroll" data-target="#contacto" class="w-full text-left px-3 py-2.5 rounded-xl text-gray-400 hover:bg-[--color-accent]/10 hover:text-white flex items-center justify-between group/item transition-colors">
          <span>📅 B_ook Call <span class="text-gray-600 font-sans font-light">— Agendar sesión de 15 min</span></span>
          <span class="text-gray-600 group-hover/item:text-[--color-accent]">⌥ 2</span>
        </button>
      </li>
      <li>
        <button data-action="download" data-target="/resume.pdf" class="w-full text-left px-3 py-2.5 rounded-xl text-gray-400 hover:bg-[--color-accent]/10 hover:text-white flex items-center justify-between group/item transition-colors">
          <span>📄 D_ownload CV <span class="text-gray-600 font-sans font-light">— Descargar perfil PDF</span></span>
          <span class="text-gray-600 group-hover/item:text-[--color-accent]">⌥ 3</span>
        </button>
      </li>
      <li>
        <button id="btn-toggle-glow" data-action="custom" class="w-full text-left px-3 py-2.5 rounded-xl text-gray-400 hover:bg-[--color-accent]/10 hover:text-white flex items-center justify-between group/item transition-colors">
          <span>💡 T_oggle Glows <span class="text-gray-600 font-sans font-light">— Encender/Apagar luces del sitio</span></span>
          <span class="text-gray-600 group-hover/item:text-[--color-accent]">⌥ 4</span>
        </button>
      </li>
    </ul>

    <!-- Footer de Ayuda -->
    <div class="mt-3 pt-2 border-t border-white/5 flex items-center justify-between font-mono text-[9px] text-gray-500 px-1">
      <span>Navega con <span class="text-gray-400">↑ ↓</span> y <span class="text-gray-400">Enter</span></span>
      <span>Ctrl + K para abrir</span>
    </div>

  </div>
</div>

<script is:inline>
  function setupCommandPalette() {
    const palette = document.getElementById('command-palette');
    const input = document.getElementById('palette-input');
    const options = document.getElementById('palette-options');
    const buttons = options.querySelectorAll('button');
    let isOpen = false;

    // Abrir/Cerrar la paleta
    function togglePalette(show) {
      isOpen = show !== undefined ? show : !isOpen;
      if (isOpen) {
        palette.classList.remove('hidden', 'pointer-events-none');
        setTimeout(() => {
          palette.classList.remove('opacity-0');
          palette.firstElementChild.classList.remove('scale-95');
          input.focus();
        }, 10);
      } else {
        palette.classList.add('opacity-0');
        palette.firstElementChild.classList.add('scale-95');
        setTimeout(() => {
          palette.classList.add('hidden', 'pointer-events-none');
        }, 300);
        input.value = '';
      }
    }

    // Escuchar atajo Ctrl+K o Cmd+K
    window.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        togglePalette();
      }
      if (e.key === 'Escape' && isOpen) {
        togglePalette(false);
      }
    });

    // Cerrar al hacer clic en el fondo difuminado
    palette.addEventListener('click', (e) => {
      if (e.target === palette) togglePalette(false);
    });

    // Atajos rápidos directos (Alt + Número o Letra clave)
    window.addEventListener('keydown', (e) => {
      if (e.altKey && !isOpen) {
        if (e.key === '1') { e.preventDefault(); window.location.href = '/'; }
        if (e.key === '2') { e.preventDefault(); document.getElementById('contacto')?.scrollIntoView({ behavior: 'smooth' }); }
        if (e.key === '3') { e.preventDefault(); window.open('/resume.pdf', '_blank'); }
        if (e.key === '4') { e.preventDefault(); document.getElementById('btn-toggle-glow')?.click(); }
      }
    });

    // Lógica para ejecutar acciones al dar clic o Enter en una opción
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const action = btn.getAttribute('data-action');
        const target = btn.getAttribute('data-target');

        togglePalette(false); // Cerramos antes de ejecutar

        if (action === 'goto') window.location.href = target;
        if (action === 'scroll') document.getElementById('contacto')?.scrollIntoView({ behavior: 'smooth' });
        if (action === 'download') window.open(target, '_blank');
        if (action === 'custom') {
          // Cambiar variable global de luces css de tu spotlight
          const root = document.documentElement;
          const currentGlow = root.style.getPropertyValue('--glow-opacity') || '1';
          root.style.setProperty('--glow-opacity', currentGlow === '1' ? '0' : '1');
          
          // Efecto visual rápido de feedback en el body
          document.body.classList.toggle('bg-zinc-950');
        }
      });
    });

    // Filtrado ultra básico de comandos (Buscador)
    input.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      buttons.forEach(btn => {
        const text = btn.textContent.toLowerCase();
        if (text.includes(term)) {
          btn.parentElement.classList.remove('hidden');
        } else {
          btn.parentElement.classList.add('hidden');
        }
      });
    });
  }

  // Correr en carga inicial y con View Transitions
  setupCommandPalette();
  document.addEventListener('astro:page-load', setupCommandPalette);
</script>