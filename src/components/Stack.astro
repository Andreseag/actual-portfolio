---
const technologies = [
  { name: "Astro", level: "Expert", icon: "🚀" },
  { name: "React", level: "Advanced", icon: "⚛️" },
  { name: "Go", level: "Intermediate", icon: "🔵" }, // Nueva incorporación
  { name: "Node.js", level: "Advanced", icon: "🟢" }, // Reforzado
  { name: "TypeScript", level: "Advanced", icon: "📘" },
  { name: "Strapi", level: "Advanced", icon: "💜" }, // Nueva incorporación
  { name: "Tailwind v4", level: "Expert", icon: "🎨" },
  { name: "Next.js", level: "Advanced", icon: "📁" },
];
---

<section class="max-w-6xl mx-auto px-6 py-24">
  <div class="reveal space-y-12">
    <div class="space-y-4">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tighter">Toolkit Técnico</h2>
      <p class="text-gray-400 max-w-xl">
        Mi enfoque se centra en utilizar las herramientas más modernas para garantizar la <span class="text-white">velocidad</span> y la <span class="text-white">escalabilidad</span>.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {technologies.map((tech) => (
        <div class="group relative overflow-hidden rounded-2xl border border-white/5 bg-white/2 p-6 transition-all duration-300 hover:border-[--color-accent]/30 hover:bg-white/5">
          <div class="relative z-10 flex items-center gap-4">
            <span class="text-2xl">{tech.icon}</span>
            <div>
              <h3 class="font-bold text-white">{tech.name}</h3>
              <p class="text-xs text-gray-500 font-mono">{tech.level}</p>
            </div>
          </div>
          
          <div 
            class="pointer-events-none absolute -inset-px opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            style="background: radial-gradient(100px circle at var(--x) var(--y), rgba(59, 130, 246, 0.1), transparent 80%);"
          ></div>
        </div>
      ))}
    </div>
  </div>
</section>