---
const currentYear = new Date().getFullYear();
const email = "castrogomezand@gmail.com";
---

<footer id="footer" class="relative max-w-6xl mx-auto px-6 py-24 border-t border-white/5">
  <div class="reveal space-y-20">
    
    <div class="flex flex-col items-center text-center space-y-8">
      <h2 class="text-5xl md:text-8xl font-bold tracking-tighter leading-none">
        ¿TIENES UNA <span class="text-gray-500">IDEA?</span><br />
        <span class="bg-linear-to-r from-blue-400 to-[--color-accent] bg-clip-text text-transparent">
          HABLEMOS.
        </span>
      </h2>
      
      <a 
        href="mailto:castrogomezand@gmail.com"
        id="copy-email"
        class="group cursor-pointer relative px-12 py-6 rounded-full bg-white text-black font-bold text-xl transition-all duration-300 hover:scale-105 active:scale-95 hover:shadow-[0_0_30px_rgba(59,130,246,0.5)]"
      >
        <span id="btn-text">{email}</span>
        
        <span id="copy-tooltip" class="absolute -top-12 left-1/2 -translate-x-1/2 bg-[--color-accent] text-white text-sm px-4 py-2 rounded-lg opacity-0 transition-opacity pointer-events-none shadow-lg">
          ¡Copiado!
        </span>
      </a>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center pt-12 gap-8">
      <div class="flex gap-8 font-mono text-sm">
        <a href="https://github.com/Andreseag" class="text-gray-500 hover:text-[--color-accent] transition-colors uppercase">Github</a>
        <a href="https://www.linkedin.com/in/andreseag" class="text-gray-500 hover:text-[--color-accent] transition-colors uppercase">Linkedin</a>
      </div>

      <p class="text-gray-600 text-xs font-mono italic">
        © {currentYear} — Built with Blue Passion & Astro
      </p>
    </div>
  </div>
</footer>

<script is:inline define:vars={{ email }}>
  const btn = document.getElementById('copy-email');
  const tooltip = document.getElementById('copy-tooltip');

  btn?.addEventListener('click', () => {
    navigator.clipboard.writeText(email);
    if (tooltip) {
      tooltip.style.opacity = '1';
      setTimeout(() => { tooltip.style.opacity = '0'; }, 2000);
    }
  });
</script>