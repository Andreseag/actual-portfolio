---
// src/components/ProjectList.astro
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    title: "Achs",
    description: "La ACHS (Asociación Chilena de Seguridad) es una mutualidad privada sin fines de lucro que se encarga de la seguridad y salud en el trabajo en Chile",
    tags: ["Astro", "Tailwind v4", "React"],
    link: "https://www.achs.cl/",
    size: "md:col-span-2 md:row-span-2" // El destacado
  },
  {
    title: "Viva Leer",
    description: "Viva Leer es el programa de fomento a la lectura de Copec, desarrollado en conjunto con la Fundación La Fuente y acogido a la Ley de Donaciones Culturales en Chile.",
    tags: ["Three.js", "GSAP"],
    link: "https://qa.vivaleercopec.cl/",
    size: "md:col-span-1"
  },
  {
    title: "Neivor",
    description: "Neivor es una plataforma tecnológica (una PropTech) diseñada para transformar la gestión de condominios, edificios y propiedades en renta en América Latina.",
    tags: ["TypeScript", "D3.js"],
    link: "https://www.neivor.com/",
    size: "md:col-span-1"
  },
  {
    title: "Quick",
    description: "Quick (quick.com.co) es una plataforma tecnológica de logística 100% colombiana que ha revolucionado el sector del transporte y la distribución en Latinoamérica y Estados Unidos.",
    tags: ["Astro", "Framer Motion"],
    link: "https://quick.com.co/",
    size: "md:col-span-3" // Ocupa todo el ancho abajo
  }
];
---

<section id="proyectos" class="max-w-6xl mx-auto px-6 py-24">
  <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
    <div class="space-y-4">
      <div class="flex items-center gap-2 text-[--color-accent] font-mono text-sm">
        <span class="w-8 h-px bg-[--color-accent]"></span>
        TRABAJOS SELECCIONADOS
      </div>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tighter">
        Proyectos que <span class="text-gray-500">marcan la diferencia.</span>
      </h2>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {projects.map((project, index) => (
      <ProjectCard 
        title={project.title}
        description={project.description}
        tags={project.tags}
        link={project.link}
        class={`${project.size} reveal reveal-delay-${index % 3}`}
      />
    ))}
  </div>
</section>