---
// src/components/ProjectList.astro
import { Image } from 'astro:assets';

// Importamos las imágenes localmente para que Astro las optimice (WebP/AVIF automático)
import imgProyecto1 from '../assets/proyecto-neivor.png';
import imgProyecto2 from '../assets/proyecto-quick.png';
import imgProyecto3 from '../assets/proyecto-vivaleer.png';
import imgProyecto4 from '../assets/proyecto-achs.png';

const projects = [
  {
    title: "Neivor PropTech Platform",
    description: "Optimización del flujo de pagos y UI components para la gestión de condominios en Latam.",
    tags: ["Vuejs", "TypeScript", "Tailwind", "Flutter"],
    link: "neivor-platform",
    image: imgProyecto1,
    alt: "Dashboard interactivo de Neivor"
  },
  {
    title: "Quick Logistics TMS",
    description: "Desarrollo del sistema de ruteo inteligente en tiempo real y tracking de última milla.",
    tags: ["React", "Javascript", "Tailwind v4"],
    link: "quick-logistics",
    image: imgProyecto2,
    alt: "Interfaz de monitoreo de Quick Logistics"
  },
  {
    title: "Viva Leer Copec Digital",
    description: "Plataforma educativa y catálogo de cuentos interactivos de alto rendimiento.",
    tags: ["Nextjs", "Wordpress", "Tailwind v4"],
    link: "viva-leer-copec",
    image: imgProyecto3,
    alt: "Plataforma web de Viva Leer Copec"
  },
  {
    title: "Plataformas ACHS",
    description: "Creación de funcionalidades en las direntes plataformas de la Aseguradora ACHS en chile.",
    tags: ["Javascript", "Bootstrap", "Sitefinity"],
    link: "plataformas-achs",
    image: imgProyecto4,
    alt: "Dashboard interactivo de Neivor"
  },
];
---

<section class="max-w-6xl mx-auto px-6 py-24" id="proyectos">
  <div class="space-y-12">
    <!-- Encabezado -->
    <div class="space-y-2">
      <h2 class="text-3xl md:text-5xl font-bold tracking-tighter">Proyectos <span class="text-gray-500">Destacados</span></h2>
      <p class="text-gray-400 max-w-md">Soluciones de software robustas con un enfoque obsesivo en la performance.</p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project, index) => (
        <a href={`proyectos/${project.link}`} class={`reveal reveal-delay-${index % 3} group relative flex flex-col overflow-hidden rounded-2xl border border-white/5 bg-white/[0.02] transition-all duration-500 hover:border-[--color-accent]/30 cursor-pointer`}>
          
          <!-- Contenedor de la Imagen con Filtro Azul y Zoom -->
          <div class="relative aspect-video overflow-hidden border-b border-white/5 bg-gray-900">
            <!-- Capa de overlay azul (Tu marca) -->
            <div class="absolute inset-0 z-10 bg-[--color-accent]/10 mix-blend-multiply opacity-100 group-hover:opacity-0 transition-opacity duration-500"></div>
            <div class="absolute inset-0 z-10 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
            
            <Image 
              src={project.image} 
              alt={project.alt}
              width={720}
              height={405}
              format="webp"
              class="h-full w-full object-cover object-top transition-transform duration-700 ease-out grayscale group-hover:grayscale-0 group-hover:scale-105"
            />
          </div>

          <!-- Contenido de la Tarjeta -->
          <div class="flex flex-1 flex-col p-6 space-y-4">
            <div class="space-y-2">
              <h3 class="text-xl font-bold text-white group-hover:text-[--color-accent] transition-colors duration-300">
                {project.title}
              </h3>
              <p class="text-sm text-gray-400 line-clamp-2 leading-relaxed">
                {project.description}
              </p>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 pt-2 mt-auto">
              {project.tags.map((tag) => (
                <span class="font-mono text-[10px] text-gray-400 bg-white/5 px-2 py-1 rounded-md border border-white/5 group-hover:border-[--color-accent]/10 group-hover:text-white transition-colors">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <!-- Flecha de link sutil -->
          <div class="absolute top-4 right-4 z-20 flex h-9 w-9 items-center justify-center rounded-full bg-black/60 backdrop-blur-md text-white opacity-0 transform translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 hover:bg-[--color-accent]">
            ↗
          </div>
        </a>
      ))}
    </div>
  </div>
</section>