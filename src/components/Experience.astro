---
const experiences = [
  {
    company: "LFI",
    role: "Senior Frontend Developer",
    period: "2025 — Presente",
    description: "Creación de soluciones de alto impacto en el sector salud usando Javascript Vanilla y Sitefinity",
  },
  {
    company: "Agencia Match",
    role: "Senior Frontend Developer",
    period: "2023 — 2025",
    description: "Liderazgo del equipo de arquitectura UI para plataformas construidas en React y Nextjs",
  },
  {
    company: "Katapult Labs",
    role: "SSR Frontend Developer",
    period: "2022 — 2023",
    description: "Creación de soluciones para productos e-commerce usando Vuejs, Nuxt y Typescript.",
  },
  {
    company: "Neivor",
    role: "SSR Frontend Developer",
    period: "2022 — 2022",
    description: "Creación de interfaces y funionalidades para platforma proptech con Vuejs y Flutter.",
  },
  {
    company: "Quick",
    role: "Web Developer",
    period: "2019 — 2021",
    description: "Creación de plataformas para software de logistica mediante React y Javascript",
  }
];
---

<section id="experiencia" class="max-w-6xl mx-auto px-6 py-24">
  <div class="reveal space-y-16">
    <div class="flex items-center gap-4">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tighter">Trayectoria</h2>
      <div class="h-px flex-1 bg-white/10"></div>
    </div>

    <div class="space-y-12">
      {experiences.map((exp) => (
        <div class="group relative grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-4 md:gap-12">
          <div class="text-sm font-mono text-gray-500 uppercase tracking-widest pt-1">
            {exp.period}
          </div>

          <div class="space-y-3">
            <h3 class="text-2xl font-bold text-white group-hover:text-[--color-accent] transition-colors duration-300">
              {exp.role} <span class="text-gray-500 font-light">@</span> {exp.company}
            </h3>
            <p class="text-gray-400 leading-relaxed max-w-2xl">
              {exp.description}
            </p>
          </div>
          
          <div class="absolute -bottom-6 left-0 w-full h-px bg-gradient-to-r from-white/5 to-transparent"></div>
        </div>
      ))}
    </div>
  </div>
</section>